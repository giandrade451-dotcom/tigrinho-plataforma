# PhantomArch Live Root Shell
export PS1='\[\033[0;35m\][phantomarch-live]\[\033[0m\] \[\033[0;36m\]\w\[\033[0m\] # '

alias ls='ls --color=auto'
alias ll='ls -la'
alias install='calamares'

echo ""
echo -e "\033[0;35m  👻 PhantomArch 1.0 Phantom — Live Environment\033[0m"
echo -e "\033[0;36m  Ghost in the Machine — Máxima Performance\033[0m"
echo ""
echo "  Comandos:"
echo "    install     — Abrir instalador (Calamares)"
echo "    nmtui       — Configurar Wi-Fi"
echo "    phantom-welcome — Checklist de sistema"
echo ""

# PhantomArch — Dunst Notification Configuration
# Cyberpunk Neon Theme

[global]
    monitor = 0
    follow = mouse
    width = 350
    height = 300
    origin = top-right
    offset = 12x12
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    indicate_hidden = yes
    transparency = 10
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 2
    frame_color = "#bd93f9"
    gap_size = 4
    separator_color = frame
    sort = yes

    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    corner_radius = 12
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#0a0a12ee"
    foreground = "#8b8da3"
    frame_color = "#1a1a2e"
    timeout = 5
    highlight = "#00fff7"

[urgency_normal]
    background = "#0a0a12ee"
    foreground = "#f8f8f2"
    frame_color = "#bd93f9"
    timeout = 10
    highlight = "#bd93f9"

[urgency_critical]
    background = "#0a0a12ee"
    foreground = "#ff5555"
    frame_color = "#ff5555"
    timeout = 0
    highlight = "#ff5555"
